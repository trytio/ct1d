# OpenAI Authentication — use ONE of these methods:
#
# Option 1: API key from platform.openai.com/api-keys (same account as your Codex subscription)
OPENAI_API_KEY=sk-your-openai-api-key-here
#
# Option 2: Codex OAuth token — copy from ~/.codex/auth.json after running `codex login`
# If set, CT1D will use this instead of OPENAI_API_KEY
CODEX_AUTH_TOKEN=
#
# Optional: NCBI API key for higher PubMed rate limits (10 req/sec vs 3 req/sec)
NCBI_API_KEY=
#
# Auth secret for autonomous agent cron triggers (generate any strong random string)
AUTONOMOUS_SECRET=
